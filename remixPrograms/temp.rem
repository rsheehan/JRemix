
=
Should the libraryStack be associated with blocks rather than function calls?
=

A-LIB : library
	lib func one :
		"lib func one"
		
	lib func two ↲
	
	run 
		"inside run - " ~
		lib func one ↲
	… from lib

"A-LIB:", A-LIB ↲

using A-LIB
	lib func two ↲

lib func two :
	lib func one ⊕ " lib func two"

"A-LIB:", A-LIB ↲

lib func two ↲

run ['block'] from lib :
	do 'block'
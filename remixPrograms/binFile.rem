using files

	'abc file' : open file "abc.txt" in HOME for BINARY-READING
	"File: ", 'abc file' ↲
	↲
	'binary contents' : binary read 'abc file'

	"Contents" ↲
	"========" ↲
	'binary contents' ↲
	"========" ↲

	'iterator' : byte iterator from 'abc file'
	"iterator: ", 'iterator'↲
	
	for each 'byte' in (bytes from 'abc file')
		'byte' _
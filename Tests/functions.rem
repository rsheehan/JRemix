test {
	"Single unnamed parameter function."
		(function ['a' + 1]) 3
	… expected 4
	
	"Single unnamed parameter function via variable."
		'fnc' : function ['a' + 2]
		'fnc' 4
	… expected 6
	
	"String parameter."
		'string length' : function [length of 'a']
		'string length' "Robert Sheehan"
	… expected 14
	
	"Multiple unnamed parameters."
		(function ['a' + 'b']) {4, 7}
	… expected 11
	"Multiple unnamed parameters via variable."
		'multi func' : function 
			'sum' : 'a' + 'b'
			'c' + 'sum'
		'multi func' {3, 4, 5}
	… expected 12
	
	"Single named parameter function."
		(function [length of'name']) {"name" : "Robert"}
	… expected 6

	"Single named parameter function via variable."
		'hello' : function
			"Hello " ⊕ 'name'
		'hello' {"name" : "Peter"}
	… expected "Hello Peter"

	"Multiple named parameters via variable."
		'totaller' : function 
			'x' + 'y' + 'z'
		'totaller' {"x" : 3, "y" : 9, "z" : 10}
	… expected 22
}